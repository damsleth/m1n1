#!/bin/busybox sh
/bin/busybox mount -t proc none /proc
/bin/busybox mount -t sysfs none /sys
/bin/busybox mount -t devtmpfs none /dev 2>/dev/null

echo ""
echo "==================================================="
echo "  USERSPACE IS ALIVE ON THE M4 PRO (t6040)"
echo "==================================================="
/bin/busybox uname -a
echo "--- cpuinfo ---"
/bin/busybox cat /proc/cpuinfo | /bin/busybox head -20
echo "--- cmdline ---"
/bin/busybox cat /proc/cmdline

if [ -c /dev/watchdog0 ]; then
    # Kernel apple_wdt inherits m1n1's running WD1. Keep a 30-second bite and
    # reset its counter every 10 seconds while the interactive shell is alive.
    /bin/busybox watchdog -T 30 -t 10 /dev/watchdog0 &
    echo "--- watchdog0 active (30s timeout, ping every 10s) ---"
else
    echo "--- WARNING: /dev/watchdog0 missing; m1n1 reset remains armed ---"
fi

echo "==================================================="
echo "  reaching this line = full boot to PID 1. Idling."
echo "==================================================="
exec /bin/busybox sh
