diff --git a/drivers/soc/apple/rtkit.c b/drivers/soc/apple/rtkit.c
index 1059b4bd8732..5c88af84e962 100644
--- a/drivers/soc/apple/rtkit.c
+++ b/drivers/soc/apple/rtkit.c
@@ -929,7 +929,13 @@ int apple_rtkit_wake(struct apple_rtkit *rtk)
 	if (ret)
 		return ret;
 
-	return apple_rtkit_boot(rtk);
+	ret = apple_rtkit_boot(rtk);
+	if (ret) {
+		int polled = apple_mbox_poll(rtk->mbox);
+
+		dev_info(rtk->dev, "MTPDBG RTKit wake ret=%d late poll=%d\n", ret, polled);
+	}
+	return ret;
 }
