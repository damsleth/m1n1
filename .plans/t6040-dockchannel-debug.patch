+
 	while (mbox_ctrl & mbox->hw->control_full) {
 		if (atomic) {
 			ret = readl_poll_timeout_atomic(
@@ -159,6 +162,11 @@ int apple_mbox_send(struct apple_mbox *mbox, const struct apple_mbox_msg msg,
 	writeq_relaxed(FIELD_PREP(APPLE_MBOX_MSG1_MSG, msg.msg1),
 		       mbox->regs + mbox->hw->a2i_send1);
 
+	dev_info(mbox->dev,
+		 "MTPDBG ASC sent msg0=%#llx msg1=%#x a2i=%#x i2a=%#x\n",
+		 msg.msg0, msg.msg1,
+		 readl_relaxed(mbox->regs + mbox->hw->a2i_control),
