 	spin_unlock_irqrestore(&mbox->tx_lock, flags);
 
 	return 0;
@@ -218,10 +226,14 @@ static int apple_mbox_poll_locked(struct apple_mbox *mbox)
 static irqreturn_t apple_mbox_recv_irq(int irq, void *data)
 {
 	struct apple_mbox *mbox = data;
+	int count;
 
 	spin_lock(&mbox->rx_lock);
-	apple_mbox_poll_locked(mbox);
+	count = apple_mbox_poll_locked(mbox);
 	spin_unlock(&mbox->rx_lock);
 
+	dev_info(mbox->dev, "MTPDBG ASC recv IRQ %d drained %d message(s)\n",
