diff --git a/drivers/pmdomain/apple/pmgr-pwrstate.c b/drivers/pmdomain/apple/pmgr-pwrstate.c
--- a/drivers/pmdomain/apple/pmgr-pwrstate.c
+++ b/drivers/pmdomain/apple/pmgr-pwrstate.c
@@ -224,31 +224,53 @@ static int apple_pmgr_ps_probe(struct platform_device *pdev)
 		return ret;
 	}
 
+	dev_info(dev, "PMGRDBG %s offset %#x: probe begin\n", name, ps->offset);
+
 	ps->genpd.flags |= GENPD_FLAG_IRQ_SAFE;
 	ps->genpd.name = name;
 	ps->genpd.power_on = apple_pmgr_ps_power_on;
 	ps->genpd.power_off = apple_pmgr_ps_power_off;
 
 	ret = of_property_read_u32(node, "apple,min-state", &ps->min_state);
-	if (ret == 0 && ps->min_state <= APPLE_PMGR_PS_ACTIVE)
+	if (ret == 0 && ps->min_state <= APPLE_PMGR_PS_ACTIVE) {
+		dev_info(dev, "PMGRDBG %s offset %#x: min-state write begin (%#x)\n",
+			 name, ps->offset, ps->min_state);
 		regmap_update_bits(regmap, ps->offset, APPLE_PMGR_FLAGS | APPLE_PMGR_PS_MIN,
 				   FIELD_PREP(APPLE_PMGR_PS_MIN, ps->min_state));
+		dev_info(dev, "PMGRDBG %s offset %#x: min-state write done\n",
+			 name, ps->offset);
+	}
 
+	dev_info(dev, "PMGRDBG %s offset %#x: initial state read begin\n",
+		 name, ps->offset);
 	active = apple_pmgr_ps_is_active(ps);
+	dev_info(dev, "PMGRDBG %s offset %#x: initial state read done (active=%u)\n",
+		 name, ps->offset, active);
 	if (of_property_read_bool(node, "apple,always-on")) {
 		ps->genpd.flags |= GENPD_FLAG_ALWAYS_ON;
 		if (!active) {
 			dev_warn(dev, "always-on domain %s is not on at boot\n", name);
 			/* Turn it on so pm_genpd_init does not fail */
+			dev_info(dev, "PMGRDBG %s offset %#x: always-on power-on begin\n",
+				 name, ps->offset);
 			active = apple_pmgr_ps_power_on(&ps->genpd) == 0;
+			dev_info(dev, "PMGRDBG %s offset %#x: always-on power-on done (active=%u)\n",
+				 name, ps->offset, active);
 		}
 	}
 
 	/* Turn on auto-PM if the domain is already on */
-	if (active)
+	if (active) {
+		dev_info(dev, "PMGRDBG %s offset %#x: auto-enable write begin\n",
+			 name, ps->offset);
 		regmap_update_bits(regmap, ps->offset, APPLE_PMGR_FLAGS | APPLE_PMGR_AUTO_ENABLE,
 				   APPLE_PMGR_AUTO_ENABLE);
+		dev_info(dev, "PMGRDBG %s offset %#x: auto-enable write done\n",
+			 name, ps->offset);
+	}
 
+	dev_info(dev, "PMGRDBG %s offset %#x: genpd registration begin\n",
+		 name, ps->offset);
 	ret = pm_genpd_init(&ps->genpd, NULL, !active);
 	if (ret < 0) {
 		dev_err(dev, "pm_genpd_init failed\n");
@@ -298,6 +320,9 @@ static int apple_pmgr_ps_probe(struct platform_device *pdev)
 	if (ret < 0)
 		goto err_remove;
 
+	dev_info(dev, "PMGRDBG %s offset %#x: probe done\n",
+		 name, ps->offset);
+
 	return 0;
 err_remove:
 	of_genpd_del_provider(node);
@@ -324,4 +349,18 @@ static struct platform_driver apple_pmgr_ps_driver = {
 MODULE_AUTHOR("Hector Martin <marcan@marcan.st>");
 MODULE_DESCRIPTION("PMGR power state driver for Apple SoCs");
 
-module_platform_driver(apple_pmgr_ps_driver);
+/*
+ * T6040 bring-up diagnostic: register after ordinary device initcalls so
+ * simpledrm and fbcon are alive before any PMGR register access can stall.
+ */
+static int __init apple_pmgr_ps_driver_init(void)
+{
+	return platform_driver_register(&apple_pmgr_ps_driver);
+}
+late_initcall(apple_pmgr_ps_driver_init);
+
+static void __exit apple_pmgr_ps_driver_exit(void)
+{
+	platform_driver_unregister(&apple_pmgr_ps_driver);
+}
+module_exit(apple_pmgr_ps_driver_exit);
